#: client/gdaemonfile.c:437
msgid "Operation not supported, files on different mounts"
msgstr "ການດຳເນີນການບໍ່ຮອງຮັບ, ໄຟລ໌ຢູ່ຄົນລະຈຸດເຊື່ອມຕໍ່"

#: client/gdaemonfile.c:1045 client/gdaemonfile.c:3079
#: client/gvfsiconloadable.c:366 daemon/gvfsjobopenforread.c:183
#: daemon/gvfsjobopenforwrite.c:356
msgid "Couldn’t get stream file descriptor"
msgstr "ບໍ່ສາມາດຮັບຕົວອະທິບາຍໄຟລ໌ສະຕຣີມໄດ້"

#: client/gdaemonfile.c:1161 client/gdaemonfile.c:1233
#: client/gvfsiconloadable.c:147
msgid "Didn’t get stream file descriptor"
msgstr "ບໍ່ໄດ້ຮັບຕົວອະທິບາຍໄຟລ໌ສະຕຣີມ"

#: client/gdaemonfile.c:1358
#, c-format
msgid "Invalid return value from %s"
msgstr "ຄ່າທີ່ສົ່ງຄືນຈາກ %s ບໍ່ຖືກຕ້ອງ"

#. translators: this is an error message when there is no user visible "mount" object
#. corresponding to a particular path/uri
#: client/gdaemonfile.c:2208 client/gdaemonfile.c:3345
msgid "Could not find enclosing mount"
msgstr "ບໍ່ສາມາດຊອກຫາຈຸດເຊື່ອມຕໍ່ທີ່ຄອບຄຸມໄດ້"

#: client/gdaemonfile.c:2240
#, c-format
msgid "Invalid filename %s"
msgstr "ຊື່ໄຟລ໌ %s ບໍ່ຖືກຕ້ອງ"

#: client/gdaemonfile.c:2554 client/gdaemonfile.c:2564
#: client/gdaemonfile.c:2586 client/gdaemonvfs.c:1234 client/gdaemonvfs.c:1255
#: client/gdaemonvfs.c:1266 client/gdaemonvfs.c:1298
#, c-format
msgid "Error setting file metadata: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການຕັ້ງຄ່າເມຕາເດຕາຂອງໄຟລ໌: %s"

#: client/gdaemonfile.c:2555 client/gdaemonvfs.c:1256
msgid "can’t open metadata tree"
msgstr "ບໍ່ສາມາດເປີດຕົ້ນໄມ້ເມຕາເດຕາໄດ້"

#: client/gdaemonfile.c:2565 client/gdaemonvfs.c:1267
msgid "can’t get metadata proxy"
msgstr "ບໍ່ສາມາດຮັບພຣັອກຊີເມຕາເດຕາໄດ້"

#: client/gdaemonfile.c:2587 client/gdaemonvfs.c:1299
msgid "values must be string or list of strings"
msgstr "ຄ່າຕ້ອງເປັນສະຕຣິງ ຫຼື ລາຍການຂອງສະຕຣິງ"

#: client/gdaemonfileinputstream.c:544 client/gdaemonfileinputstream.c:552
#: client/gdaemonfileinputstream.c:1686 client/gdaemonfileinputstream.c:1695
#: client/gdaemonfileoutputstream.c:495 client/gdaemonfileoutputstream.c:503
#: client/gdaemonfileoutputstream.c:1433 client/gdaemonfileoutputstream.c:1442
#, c-format
msgid "Error in stream protocol: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນໂປຣໂຕຄໍສະຕຣີມ: %s"

#: client/gdaemonfileinputstream.c:552 client/gdaemonfileinputstream.c:1695
#: client/gdaemonfileoutputstream.c:503 client/gdaemonfileoutputstream.c:1442
#: daemon/gvfsbackendmtp.c:2504 daemon/gvfsbackendmtp.c:2941
msgid "End of stream"
msgstr "ຈົບສະຕຣີມ"

#: client/gdaemonfileinputstream.c:649 client/gdaemonfileinputstream.c:802
#: client/gdaemonfileinputstream.c:922 client/gdaemonfileinputstream.c:1173
#: client/gdaemonfileinputstream.c:1418 client/gdaemonfileoutputstream.c:553
#: client/gdaemonfileoutputstream.c:731 client/gdaemonfileoutputstream.c:926
#: client/gdaemonfileoutputstream.c:1092 client/gdaemonfileoutputstream.c:1274
#: daemon/gvfsbackendsftp.c:5521 daemon/gvfsbackendsmb.c:1160
#: daemon/gvfsbackendtest.c:92 daemon/gvfsbackendtest.c:125
#: daemon/gvfsbackendtest.c:188 daemon/gvfschannel.c:347
#: daemon/gvfsftptask.c:224
msgid "Operation was cancelled"
msgstr "ການດຳເນີນການຖືກຍົກເລີກແລ້ວ"

#: client/gdaemonfileinputstream.c:1355 client/gdaemonfileoutputstream.c:1035
msgid "Seek not supported on stream"
msgstr "ການຊອກຫາບໍ່ຮອງຮັບໃນສະຕຣີມ"

#: client/gdaemonfileoutputstream.c:1204
msgid "Truncate not supported on stream"
msgstr "ການຕັດທອນບໍ່ຮອງຮັບໃນສະຕຣີມ"

#: client/gdaemonvfs.c:780
#, c-format
msgid "Error while getting mount info: %s"
msgstr "ເກີດຂໍ້ຜິດພາດຂະນະກຳລັງຮັບຂໍ້ມູນຈຸດເຊື່ອມຕໍ່: %s"

#: client/gvfsdaemondbus.c:292 client/gvfsdaemondbus.c:666
#: daemon/gvfsafpvolume.c:394 daemon/gvfsafpvolume.c:655
#: daemon/gvfsafpvolume.c:799 daemon/gvfsafpvolume.c:981
#: daemon/gvfsafpvolume.c:1165 daemon/gvfsafpvolume.c:1340
#: daemon/gvfsafpvolume.c:1492 daemon/gvfsafpvolume.c:1914
#: daemon/gvfsafpvolume.c:2035 daemon/gvfsafpvolume.c:2190
#: daemon/gvfsafpvolume.c:2403 daemon/gvfsbackendadmin.c:150
#: daemon/gvfsbackendafc.c:166 daemon/gvfsbackendgoogle.c:256
#: daemon/gvfsbackendsftp.c:346 daemon/gvfsbackendsftp.c:1125
#: daemon/gvfsbackendsftp.c:2215 daemon/gvfsftptask.c:438 daemon/mount.c:437
#, c-format
msgid "Permission denied"
msgstr "ການອະນຸຍາດຖືກປະຕິເສດ"

#: common/gvfsdaemonprotocol.c:358
msgid "Invalid file info format"
msgstr "ຮູບແບບຂໍ້ມູນໄຟລ໌ບໍ່ຖືກຕ້ອງ"

#: common/gvfsdnssdresolver.c:216
#, c-format
msgid "Error initializing Avahi: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເລີ່ມຕົ້ນ Avahi: %s"

#. Translators:
#. * - the first %s refers to the service type
#. * - the second %s refers to the service name
#. * - the third %s refers to the domain
#.
#: common/gvfsdnssdresolver.c:1144
#, c-format
msgid "Error resolving “%s” service “%s” on domain “%s”"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການແກ້ໄຂບໍລິການ “%s” ຊື່ “%s” ໃນໂດເມນ “%s”"

#. Translators:
#. * - the first %s refers to the service type
#. * - the second %s refers to the service name
#. * - the third %s refers to the domain
#. * - the fourth %s refers to the required TXT keys
#.
#: common/gvfsdnssdresolver.c:1168
#, c-format
msgid ""
"Error resolving “%s” service “%s” on domain “%s”. One or more TXT records "
"are missing. Keys required: “%s”."
msgstr "ເກີດຂໍ້ຜິດພາດໃນການແກ້ໄຂບໍລິການ “%s” ຊື່ “%s” ໃນໂດເມນ “%s”. ບັນທຶກ TXT ໜຶ່ງລາຍການ ຫຼື ຫຼາຍກວ່ານັ້ນຫາຍໄປ. ຄີທີ່ຕ້ອງການ: “%s”."

#. Translators:
#. * - the first %s refers to the service type
#. * - the second %s refers to the service name
#. * - the third %s refers to the domain
#.
#: common/gvfsdnssdresolver.c:1183
#, c-format
msgid "Timed out resolving “%s” service “%s” on domain “%s”"
msgstr "ໝົດເວລາໃນການແກ້ໄຂບໍລິການ “%s” ຊື່ “%s” ໃນໂດເມນ “%s”"

#: common/gvfsdnssdresolver.c:1223
msgid "Error initializing Avahi resolver"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເລີ່ມຕົ້ນຕົວແກ້ໄຂ Avahi"

#: common/gvfsdnssdutils.c:233 common/gvfsdnssdutils.c:263
#: common/gvfsdnssdutils.c:280
#, c-format
msgid "Malformed DNS-SD encoded_triple “%s”"
msgstr "ຮູບແບບ encoded_triple ຂອງ DNS-SD “%s” ບໍ່ຖືກຕ້ອງ"

#: common/gvfsicon.c:250
#, c-format
msgid "Can’t handle version %d of GVfsIcon encoding"
msgstr "ບໍ່ສາມາດຈັດການການເຂົ້າລະຫັດ GVfsIcon ເວີຊັນ %d ໄດ້"

#: common/gvfsicon.c:260
msgid "Malformed input data for GVfsIcon"
msgstr "ຂໍ້ມູນປ້ອນເຂົ້າສຳລັບ GVfsIcon ມີຮູບແບບບໍ່ຖືກຕ້ອງ"

#. translators: This is the default daemon's application name,
#. * the %s is the type of the backend, like "FTP"
#: daemon/daemon-main.c:100
#, c-format
msgid "%s File System Service"
msgstr "ບໍລິການລະບົບໄຟລ໌ %s"

#: daemon/daemon-main.c:178
#, c-format
msgid "Error: %s"
msgstr "ຂໍ້ຜິດພາດ: %s"

#: daemon/daemon-main.c:236
#, c-format
msgid "Usage: %s --spawner dbus-id object_path"
msgstr "ການນຳໃຊ້: %s --spawner dbus-id object_path"

#: daemon/daemon-main.c:260 daemon/daemon-main.c:278
#, c-format
msgid "Usage: %s key=value key=value …"
msgstr "ການນຳໃຊ້: %s key=value key=value …"

#: daemon/daemon-main.c:276
msgid "No mount type specified"
msgstr "ບໍ່ໄດ້ລະບຸປະເພດຈຸດເຊື່ອມຕໍ່"

#: daemon/daemon-main.c:308
#, c-format
msgid "mountpoint for %s already running"
msgstr "ຈຸດເຊື່ອມຕໍ່ສຳລັບ %s ກຳລັງເຮັດວຽກຢູ່ແລ້ວ"

#: daemon/daemon-main.c:337
msgid "error starting mount daemon"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເລີ່ມຕົ້ນເດມອນຈຸດເຊື່ອມຕໍ່"

#: daemon/gvfsafpconnection.c:787
msgid "The connection is not opened"
msgstr "ການເຊື່ອມຕໍ່ບໍ່ໄດ້ຖືກເປີດ"

#: daemon/gvfsafpconnection.c:794
msgid "The connection is closed"
msgstr "ການເຊື່ອມຕໍ່ຖືກປິດແລ້ວ"

#: daemon/gvfsafpconnection.c:897
msgid "Got EOS"
msgstr "ໄດ້ຮັບ EOS"

#: daemon/gvfsafpconnection.c:1060 daemon/gvfsafpconnection.c:1102
#: daemon/gvfsftptask.c:398
msgid "Host closed connection"
msgstr "ໂຮສຕ໌ປິດການເຊື່ອມຕໍ່ແລ້ວ"

#: daemon/gvfsafpconnection.c:1521
msgid "Connection unexpectedly went down"
msgstr "ການເຊື່ອມຕໍ່ຂາດໄປຢ່າງບໍ່ຄາດຄິດ"

#: daemon/gvfsafpconnection.c:1548
msgid "Got unexpected end of stream"
msgstr "ໄດ້ຮັບການສິ້ນສຸດຂອງສະຕຣີມຢ່າງບໍ່ຄາດຄິດ"

#. Translators: %d is a constant, currently hardcoded to 256
#: daemon/gvfsafpserver.c:195 daemon/gvfsafpserver.c:477
#, c-format
msgid "The server doesn’t support passwords longer than %d character."
msgstr "ເຊີບເວີບໍ່ຮອງຮັບລະຫັດຜ່ານທີ່ຍາວກວ່າ %d ຕົວອັກສອນ."

#: daemon/gvfsafpserver.c:221 daemon/gvfsafpserver.c:530
msgid "An invalid username was provided."
msgstr "ຊື່ຜູ້ໃຊ້ທີ່ລະບຸບໍ່ຖືກຕ້ອງ."

#: daemon/gvfsafpserver.c:390
#, c-format
msgid "Unable to login to the server “%s” with the given password."
msgstr "ບໍ່ສາມາດເຂົ້າສູ່ລະບົບເຊີບເວີ “%s” ດ້ວຍລະຫັດຜ່ານທີ່ລະບຸໄດ້."

#: daemon/gvfsafpserver.c:425 daemon/gvfsafpserver.c:647
#: daemon/gvfsafpserver.c:823 daemon/gvfsafpserver.c:871
#: daemon/gvfsafpserver.c:987 daemon/gvfsafpserver.c:1659
#, c-format
msgid "Unable to connect to the server “%s”. A communication problem occurred."
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບເຊີບເວີ “%s” ໄດ້. ເກີດບັນຫາໃນການສື່ສານ."

#: daemon/gvfsafpserver.c:620
#, c-format
msgid "Unable to connect to the server “%s” with the given password."
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບເຊີບເວີ “%s” ດ້ວຍລະຫັດຜ່ານທີ່ລະບຸໄດ້."

#: daemon/gvfsafpserver.c:673 daemon/gvfsafpserver.c:698
#, c-format
msgid "The server “%s” doesn’t support anonymous access."
msgstr "ເຊີບເວີ “%s” ບໍ່ຮອງຮັບການເຂົ້າເຖິງແບບບໍ່ລະບຸຊື່."

#: daemon/gvfsafpserver.c:726
#, c-format
msgid ""
"Unable to connect to the server “%s”. No suitable authentication mechanism "
"was found."
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບເຊີບເວີ “%s” ໄດ້. ບໍ່ພົບກົນໄກການຢືນຢັນຕົວຕົນທີ່ເໝາະສົມ."

#: daemon/gvfsafpserver.c:801
#, c-format
msgid ""
"Unable to connect to the server “%s”. The server doesn’t support AFP version "
"3.0 or later."
msgstr "ບໍ່ສາມາດເຊື່ອມຕໍ່ກັບເຊີບເວີ “%s” ໄດ້. ເຊີບເວີບໍ່ຮອງຮັບ AFP ເວີຊັນ 3.0 ຫຼື ສູງກວ່າ."

#: daemon/gvfsafpserver.c:912
#, c-format
msgid "Permission denied."
msgstr "ການອະນຸຍາດຖືກປະຕິເສດ."

#: daemon/gvfsafpserver.c:917
#, c-format
msgid "The command is not supported by the server."
msgstr "ຄຳສັ່ງນີ້ບໍ່ຖືກຮອງຮັບໂດຍເຊີບເວີ."

#: daemon/gvfsafpserver.c:921
#, c-format
msgid "Your password has expired."
msgstr "ລະຫັດຜ່ານຂອງທ່ານໝົດອາຍຸແລ້ວ."

#: daemon/gvfsafpserver.c:925
#, c-format
msgid "Your password needs to be changed."
msgstr "ຕ້ອງປ່ຽນລະຫັດຜ່ານຂອງທ່ານ."

#. Translators: the first %s is the username, the second the host name
#: daemon/gvfsafpserver.c:1063 daemon/gvfsbackendftp.c:531
#: daemon/gvfsbackendsftp.c:1167
#, c-format
msgid ""
"Authentication Required\n"
"Enter password for “%s” on “%s”:"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນ\nປ້ອນລະຫັດຜ່ານສຳລັບ “%s” ເທິງ “%s”:"

#. Translators: %s here is the hostname
#. Translators: %s is the hostname
#. Translators: %s is a server name
#: daemon/gvfsafpserver.c:1066 daemon/gvfsbackendftp.c:534
#: daemon/gvfsbackendsftp.c:1174 daemon/gvfsbackendsmbbrowse.c:340
#, c-format
msgid ""
"Authentication Required\n"
"Enter user and password for “%s”:"
msgstr "ຕ້ອງການການຢືນຢັນຕົວຕົນ\nປ້ອນຊື່ຜູ້ໃຊ້ ແລະ ລະຫັດຜ່ານສຳລັບ “%s”:"

#: daemon/gvfsafpserver.c:1098
msgid "The password prompt was cancelled."
msgstr "ການຮ້ອງຂໍລະຫັດຜ່ານຖືກຍົກເລີກແລ້ວ."

#: daemon/gvfsafpserver.c:1216
msgid "Unable to disconnect from the server."
msgstr "ບໍ່ສາມາດຕັດການເຊື່ອມຕໍ່ຈາກເຊີບເວີໄດ້."

#: daemon/gvfsafpserver.c:1357 daemon/gvfsafpserver.c:1733
msgid "Unable to connect to the server. A communication problem occurred."
