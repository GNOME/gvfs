#: monitor/udisks2/gvfsudisks2utils.c:646
#, c-format
msgid ""
"Unmounting %s\n"
"Disconnecting from filesystem."
msgstr "ກຳລັງຍົກເລີກການເຊື່ອມຕໍ່ %s\nກຳລັງຕັດການເຊື່ອມຕໍ່ຈາກລະບົບໄຟລ໌."

#: monitor/udisks2/gvfsudisks2utils.c:648
#, c-format
msgid ""
"Writing data to %s\n"
"Device should not be unplugged."
msgstr "ກຳລັງຂຽນຂໍ້ມູນໃສ່ %s\nບໍ່ຄວນຖອດອຸປະກອນອອກ."

#: monitor/udisks2/gvfsudisks2utils.c:784
#, c-format
msgid ""
"%s unmounted\n"
"Filesystem has been disconnected."
msgstr "%s ຖືກຍົກເລີກການເຊື່ອມຕໍ່ແລ້ວ\nລະບົບໄຟລ໌ຖືກຕັດການເຊື່ອມຕໍ່ແລ້ວ."

#: monitor/udisks2/gvfsudisks2utils.c:786
#, c-format
msgid ""
"%s can be safely unplugged\n"
"Device can be removed."
msgstr "ສາມາດຖອດ %s ອອກໄດ້ຢ່າງປອດໄພ\nສາມາດເອົາອຸປະກອນອອກໄດ້."

#. Translators: This is used for possibly encrypted volumes.
#. *              The first %s is the formatted size (e.g. "42.0 MB").
#.
#: monitor/udisks2/gvfsudisks2volume.c:304
#, c-format
msgid "%s Possibly Encrypted"
msgstr "%s ອາດຈະຖືກເຂົ້າລະຫັດ"

#. Translators: This is used for encrypted volumes.
#. *              The first %s is the formatted size (e.g. "42.0 MB").
#.
#: monitor/udisks2/gvfsudisks2volume.c:311
#, c-format
msgid "%s Encrypted"
msgstr "%s ຖືກເຂົ້າລະຫັດ"

#. Translators: This is used for volume with no filesystem label.
#. *              The first %s is the formatted size (e.g. "42.0 MB").
#.
#: monitor/udisks2/gvfsudisks2volume.c:324
#, c-format
msgid "%s Volume"
msgstr "ໂວລຸມ %s"

#. Translators: Name used for volume
#: monitor/udisks2/gvfsudisks2volume.c:565
msgid "Volume"
msgstr "ໂວລຸມ"

#: monitor/udisks2/gvfsudisks2volume.c:1160
#, c-format
